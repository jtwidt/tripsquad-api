{
    "name": "tripsquad-api",
    "version": "1.0.0",
    "description": "API for the TripSquad website and app",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "nodemon server.js",
        "format:check": "prettier --check .",
        "format:write": "prettier --write .",
        "lint:check": "eslint .",
        "lint:fix": "eslint --fix .",
        "db:start": "npx sequelize-cli db:create && npx sequelize-cli db:migrate",
        "db:reset": "npx sequelize-cli db:drop && npx sequelize-cli db:create && npx sequelize-cli db:migrate"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jtwidt/tripsquad-api.git"
    },
    "author": "Jeremy Twidt",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/jtwidt/tripsquad-api/issues"
    },
    "homepage": "https://github.com/jtwidt/tripsquad-api#readme",
    "dependencies": {
        "amadeus": "^9.1.0",
        "bcryptjs": "^2.4.3",
        "body-parser": "^1.20.2",
        "cors": "^2.8.5",
        "express": "^4.18.2",
        "jsonwebtoken": "^9.0.2",
        "pg": "^8.11.3",
        "pg-hstore": "^2.3.4",
        "sequelize": "^6.35.2",
        "uuid": "^9.0.1"
    },
    "devDependencies": {
        "dotenv": "^16.4.1",
        "eslint": "^8.56.0",
        "eslint-config-prettier": "^9.1.0",
        "nodemon": "^3.0.3",
        "prettier": "^3.2.4",
        "sequelize-cli": "^6.6.2"
    }
}
